{
    "name": "kanopi/composer-assets-drupal-custom",
    "description": "Kanopi deployment configuration for Drupal on custom/self-managed hosting (CircleCI + Tugboat, Kanopi orbs).",
    "type": "library",
    "license": "MIT",
    "keywords": ["kanopi", "drupal", "custom", "circleci", "tugboat", "deployment", "composer-assets"],
    "authors": [
        { "name": "Kanopi Studios" }
    ],
    "require": {
        "kanopi/composer-assets": "^1"
    },
    "extra": {
        "composer-assets": {
            "file-mapping": {
                ".circleci/config.yml":             { "path": "assets/circleci/config.yml", "overwrite": false, "gitignore": false },
                ".circleci/env.sh":                 { "path": "assets/circleci/env.sh", "overwrite": false, "gitignore": false },
                ".circleci/exclude-files.txt":      { "path": "assets/circleci/exclude-files.txt", "overwrite": false, "gitignore": false },
                ".tugboat/config.yml":              { "path": "assets/tugboat/config.yml", "overwrite": false, "gitignore": false },
                ".tugboat/tugboat.env":             { "path": "assets/tugboat/tugboat.env", "overwrite": false, "gitignore": false },
                ".tugboat/settings.local.php":      { "path": "assets/tugboat/settings.local.php", "overwrite": false, "gitignore": false },
                ".tugboat/scripts/common.sh":       { "path": "assets/tugboat/scripts/common.sh", "gitignore": true },
                ".tugboat/scripts/install-tools.sh":{ "path": "assets/tugboat/scripts/install-tools.sh", "gitignore": true },
                ".tugboat/scripts/build.sh":        { "path": "assets/tugboat/scripts/build.sh", "gitignore": true },
                ".tugboat/scripts/database.sh":     { "path": "assets/tugboat/scripts/database.sh", "gitignore": true },
                ".tugboat/scripts/files.sh":        { "path": "assets/tugboat/scripts/files.sh", "gitignore": true },
                ".tugboat/scripts/deploy.sh":       { "path": "assets/tugboat/scripts/deploy.sh", "gitignore": true }
            }
        }
    }
}
